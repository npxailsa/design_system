  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --config-dir .storybook --ci --no-open --loglevel debug",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 tsc && NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --config-dir .storybook",
