{
  "name": "@npxailsa/design-system",
  "version": "1.0.14",
  "description": "A React and TypeScript design system with Storybook.",
  "homepage": "https://npxailsa.github.io/design_system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/assets/index.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "EDITOR=nano storybook dev -p 6006 --config-dir .storybook --ci --no-open --loglevel debug",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 tsc && NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "build:lib": "tsc --noEmit && NODE_OPTIONS=--max-old-space-size=4096 vite build --config vite.lib.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "EDITOR=nano storybook dev -p 6006 --config-dir .storybook",
    "build-storybook": "npm run docs:generate && NODE_OPTIONS=--max-old-space-size=4096 storybook build",
    "build-storybook:gh-pages": "STORYBOOK_BASE_PATH=/design_system/ npm run docs:generate && NODE_OPTIONS=--max-old-space-size=4096 storybook build --output-dir storybook-static && touch storybook-static/.nojekyll",
    "docs:generate": "node scripts/generate-docs.mjs",
    "chromatic": "NODE_OPTIONS=--max-old-space-size=4096 npx chromatic --project-token=chpt_44a4334f1199317 --build-script-name=build-storybook"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "5.0.1",
    "@storybook/addon-a11y": "10.2.17",
    "@storybook/addon-docs": "10.2.17",
    "@storybook/addon-links": "10.2.17",
    "@storybook/addon-themes": "10.2.17",
    "@storybook/addon-vitest": "10.2.17",
    "@storybook/react": "10.2.17",
    "@storybook/react-vite": "10.2.17",
    "@storybook/test-runner": "^0.24.2",
    "@testing-library/dom": "10.4.1",
    "@types/aria-query": "5.0.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "4.1.0",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/runner": "4.1.0",
    "aria-query": "5.3.0",
    "chromatic": "^15.2.0",
    "dom-accessibility-api": "0.5.16",
    "eslint": "10.0.3",
    "lz-string": "1.5.0",
    "pretty-format": "27.5.1",
    "storybook": "10.2.17",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "4.1.0",
    "yaml": "^2.8.2"
  },
  "overrides": {}
}
