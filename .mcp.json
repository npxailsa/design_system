{
  "mcpServers": {
    "npx-design-system-sb-mcp": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "gemini-cli": {
      "type": "stdio",
      "command": "gemini",
      "args": ["mcp", "serve"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${input:github_mcp_pat}"}
    },
  "inputs": [ {
    "type": "promptString",
    "id": "github_mcp_pat",
    "description": "GitHub Personal Access Token",
    "password": true 
   } ] 
  }
}