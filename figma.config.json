{
  "codeConnect": {
    "parser": "react",
    "label": "React",
    "language": "tsx",
    "include": ["src/**/*.figma.ts"],
    "exclude": [
      "dist/**",
      "build/**",
      "storybook-static/**",
      "node_modules/**",
      "**/*.stories.tsx",
      "**/*.test.tsx",
      "**/*.spec.tsx"
    ],
    "defaultBranch": "main",
    "importPaths": {
      "src/components/*": "@npxailsa/design-system"
    }
  }
}
